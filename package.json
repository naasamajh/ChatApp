{
    "name": "incognichat",
    "version": "1.0.0",
    "description": "IncogniChat - Anonymous Real-time Chatroom. No signup, no history, just chat.",
    "main": "server.js",
    "scripts": {
        "dev:client": "vite",
        "dev:server": "node --watch server.js",
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "build": "vite build",
        "start": "node server.js",
        "render-build": "npm install && npm run build"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "groq-sdk": "^0.37.0",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.12.1",
        "socket.io": "^4.8.1",
        "framer-motion": "^11.18.2",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hot-toast": "^2.5.2",
        "react-icons": "^5.4.0",
        "react-router-dom": "^7.2.0",
        "socket.io-client": "^4.8.1"
    },
    "devDependencies": {
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.3",
        "@vitejs/plugin-react": "^4.3.4",
        "concurrently": "^9.1.2",
        "vite": "^6.1.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}